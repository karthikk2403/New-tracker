{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "MEMBER"], "description": "Global role, though project-specific roles are preferred" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A collaborative project containing tasks and members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { 
          "type": "object",
          "description": "Map of user IDs to roles (ADMIN, MEMBER)"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "members"]
    },
    "Task": {
      "title": "Task",
      "description": "A specific task within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed", "archived"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "assignedTo": { "type": "string", "description": "User ID of the assigned member" },
        "viewerIds": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status", "priority", "createdBy", "viewerIds"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["taskId", "userId", "text", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A log of activity within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["projectId", "userId", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Users collection"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects collection"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks collection"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments collection"
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "Activity logs"
    }
  }
}
